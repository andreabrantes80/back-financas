{
  "compilerOptions": {
    "target": "ES2020",              /* Versão moderna do JS */
    "module": "commonjs",            /* Compatível com Node */
    "outDir": "./dist",              /* Pasta de saída */
    "rootDir": "./src",              /* Pasta de entrada */
    "strict": true,                  /* Boa prática: validação estrita */
    "esModuleInterop": true,         /* Permite import/export padrão */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],                /* Compilar apenas src/ */
  "exclude": ["node_modules"]        /* Ignorar node_modules */
}